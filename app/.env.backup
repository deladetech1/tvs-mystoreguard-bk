# =============================================================================
# Production Settings
# =============================================================================
# Uncomment and modify for production
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# SECRET_KEY=your-production-secret-key-here
# DATABASE_URL=postgresql://prod_user:prod_password@prod_host:5432/prod_db